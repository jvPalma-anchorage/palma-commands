---- ./python/prs/prs/cli.py ----
import argparse
import sys
from prs.config import get, set, all_config
from prs.core.usecases import list_pull_requests

def run_cli():
    parser = argparse.ArgumentParser(prog="nprs", description="PRS - Pull Request Status CLI")
    subparsers = parser.add_subparsers(dest="command")

    # Optional subcommand: 'list'
    subparsers.add_parser("list", help="List your pull requests")

    # Config commands
    config_parser = subparsers.add_parser("config", help="Get or set configuration")
    config_parser.add_argument("action", choices=["get", "set", "all"])
    config_parser.add_argument("key", nargs="?", help="Ex: git.username")
    config_parser.add_argument("value", nargs="?", help="Value to set (used with 'set')")

    # Parse args
    args = parser.parse_args()

    # Default action: if no subcommand given, run 'list'
    if args.command is None or args.command == "list":
        list_pull_requests()

    if args.command == "config":
        if args.action == "get":
            if not args.key:
                print("You must provide a key. Example: git.username")
                sys.exit(1)
            section, key = args.key.split(".")
            print(get(section, key))

        elif args.action == "set":
            if not args.key or not args.value:
                print("Usage: nprs config set git.username yourName")
                sys.exit(1)
            section, key = args.key.split(".")
            set(section, key, args.value)
            print(f"Set {section}.{key} = {args.value}")

        elif args.action == "all":
            for section, items in all_config().items():
                print(f"[{section}]")
                for key, value in items.items():
                    print(f"{key} = {value}")
                print()
        return






---- ./python/prs/prs/config.py ----
import configparser
import os
from pathlib import Path

CONFIG_PATH = Path.home() / ".prsconfig"

_config = configparser.ConfigParser()

# Cria config inicial se nГЈo existir
if not CONFIG_PATH.exists():
    CONFIG_PATH.write_text("[core]\nrepo = \nusername = \n")

_config.read(CONFIG_PATH)


def get(section: str, key: str, fallback: str = "") -> str:
    return _config.get(section, key, fallback=fallback)


def set(section: str, key: str, value: str) -> None:
    if not _config.has_section(section):
        _config.add_section(section)
    _config.set(section, key, value)
    with open(CONFIG_PATH, "w") as configfile:
        _config.write(configfile)


def all_config() -> dict:
    return {s: dict(_config.items(s)) for s in _config.sections()}




