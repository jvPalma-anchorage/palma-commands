---- ./python/prs/prs/vc_tools/github/adapter.py ----
from prs.core.models import PullRequest

def to_model(pr_json: dict) -> PullRequest:
    """
    Transform the raw JSON from get_pull_request_details into a PullRequest model.
    """
    pr_id = pr_json.get("number", 0)
    title = pr_json.get("title", "")
    author = pr_json.get("author", {}).get("login", "")
    labels = [lbl.get("name", "") for lbl in pr_json.get("labels", [])]
    checks_raw = pr_json.get("statusCheckRollup", [])
    reviews_raw = pr_json.get("reviews", [])
    url = pr_json.get("url", "")
    branch = pr_json.get("headRefName", "")
    is_draft = pr_json.get("isDraft", False)

    return PullRequest(
        id=pr_id,
        title=title,
        author=author,
        labels=labels,
        checks=checks_raw,
        reviews=reviews_raw,
        url=url,
        branch=branch,
        is_draft=is_draft
    )




---- ./python/prs/prs/vc_tools/github/client.py ----
from prs.config import get
from prs.core.helpers import read_authors, resolve_owner
import subprocess
import json

def list_pr_ids_by_authors():
    """
    Reads authors from the config (or fallback),
    fetches all PRs, filters locally,
    and returns a list of (number, 'authored').
    """
    authors = read_authors()
    raw_prs = list_prs_all(authors)
    result = []
    for pr in raw_prs:
        pr_number = pr.get("number")
        if pr_number:
            result.append((pr_number, "authored"))
    return result

def list_prs_all(authors=None):
    """
    Returns a list of dictionaries with raw info of all PRs in the repository.
    If authors != None, filters locally only the PRs of this/these author(s).
    """
    if authors is None:
        authors = []

    owner = resolve_owner()
    repo_name = get("git", "repo_name")

    gh_args = [
        "gh", "api",
        f"repos/{owner}/{repo_name}/pulls",
        "--paginate --author rpereira-anchor",
    ]

    try:
        output = subprocess.check_output(gh_args, text=True)
        data = json.loads(output)  # list of PRs
    except subprocess.CalledProcessError as e:
        print("Error calling gh api:", e)
        return []

    if len(authors) == 0:
        return data
    else:
        filtered = []
        for pr in data:
            if pr.get("user", {}).get("login") in authors:
                filtered.append(pr)
        return filtered

def list_pull_request_ids(filters: dict) -> list[tuple[int, str]]:
    """
    Uses 'gh pr list' with certain filters.
    Returns a list of (pr_id, source_tag).
    'source_tag' can be 'authored', 'team', 'review_requested', etc.
    """
    # Example: filters might be {"author": "myUser", "state": "open"}
    # Construct the CLI args for 'gh pr list'
    gh_args = ["gh", "pr", "list", "--json", "number"]

    author = filters.get("author")
    if author:
        gh_args += ["--author", author]

    state = filters.get("state")
    if state:
        gh_args += ["--state", state]

    # others like: base branch, label, search, etc.

    # Run subprocess
    try:
        output = subprocess.check_output(gh_args, text=True)
        data = json.loads(output)
        # data is a list of PR objects (e.g. [{"number": 123}, ...])
    except subprocess.CalledProcessError as e:
        print("Error calling gh:", e)
        return []

    # Example: assume all are "authored"
    result = []
    for item in data:
        number = item.get("number")
        if number is not None:
            result.append((number, "authored"))
    return result

def get_pull_request_details(pr_id: int) -> dict:
    """
    Call 'gh pr view <pr_id>' to get the full JSON details.
    Return the raw JSON as a dictionary.
    """
    gh_args = [
        "gh",
        "pr",
        "view",
        str(pr_id),
        "--json", "number,title,author,labels,statusCheckRollup,reviews,url,headRefName,isDraft"
    ]
    try:
        output = subprocess.check_output(gh_args, text=True)
        data = json.loads(output)
        return data
    except subprocess.CalledProcessError as e:
        print("Error fetching details for PR #", pr_id, e)
        return {}



