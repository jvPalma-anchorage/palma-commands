---- ./python/prs/prs/core/helpers.py ----
from prs.config import get
import subprocess
import json

def resolve_owner():
    """
    Determines who is the 'owner' of the repository according to the config:
    - if 'username' => use git.username
    - if 'org_name' => use git-org.org_name
    - otherwise => use literal value
    """
    upstream_config = get("git", "upstream")  # ex: 'username' or 'org_name' or 'whatever'
    user_conf = get("git", "username")
    org_conf = get("git-org", "org_name")

    if upstream_config == "username":
        return user_conf
    elif upstream_config == "org_name":
        return org_conf
    else:
        return upstream_config


def read_authors():
    authors_str = get("pr-info", "authors", fallback="")

    if not authors_str.strip():
        # fallback to the git.username config
        return [get("git", "username")]
    else:
        # ex: "user-1, user-2, user-3"
        authors_list = authors_str.split(",")
        # clean up spaces
        return [a.strip() for a in authors_list if a.strip()]




---- ./python/prs/prs/core/models.py ----
class PullRequest:
    """
    Domain model for a Pull Request.
    """

    def __init__(self, id: int, title: str, author: str, labels: list[str],
                 checks: list[dict], reviews: list[dict], url: str,
                 branch: str, is_draft: bool):
        self.id = id
        self.title = title
        self.author = author
        self.labels = labels
        self.checks = checks
        self.reviews = reviews
        self.url = url
        self.branch = branch
        self.is_draft = is_draft

        # For internal usage, e.g., 'authored', 'team', 'review_requested'
        self.source = None

    def summary(self) -> str:
        return f"[#{self.id}] {self.title} by {self.author}"




---- ./python/prs/prs/core/usecases.py ----
from prs.config import get
from prs.vc_tools.github.client import list_pull_request_ids, get_pull_request_details
from prs.vc_tools.github.adapter import to_model

def list_pull_requests():
    # Example usage of config
    username = get("git", "username")
    repo_name = get("git", "repo_name")

    # Build filters
    filters = {
        "author": username,
        "state": "open"
    }

    # 1) Get minimal info first
    pr_refs = list_pull_request_ids(filters)
    all_prs = []

    # 2) Then fetch each PR in detail
    for (pr_id, source_tag) in pr_refs:
        raw = get_pull_request_details(pr_id)
        pr_model = to_model(raw)
        pr_model.source = source_tag
        all_prs.append(pr_model)

    # 3) Display
    print(f"Found {len(all_prs)} PRs for '{username}' in repo '{repo_name}'.")
    for pr in all_prs:
        print(pr.summary())




