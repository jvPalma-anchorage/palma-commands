#!/home/user/palma-commands/python/prs/.venv/bin/python3
# EASY-INSTALL-ENTRY-SCRIPT: 'prs','console_scripts','nprs'
__requires__ = 'prs'
import re
import sys
from pkg_resources import load_entry_point

if __name__ == '__main__':
    sys.argv[0] = re.sub(r'(-script\.pyw?|\.exe)?$', '', sys.argv[0])
    sys.exit(
        load_entry_point('prs', 'console_scripts', 'nprs')()
    )
